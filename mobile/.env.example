# AURA Care-Chain — variáveis de ambiente
# Copie para `.env` e preencha. O `.env` está no .gitignore.

# Backend aura-server (REST /api/v1). Em device físico use o IP da máquina, não localhost.
BACKEND_BASE_URL=http://localhost:8000

# Google Maps (rastreador de pedido)
GOOGLE_MAPS_API_KEY=

# Supabase (apenas para o token do agente de voz ElevenLabs)
SUPABASE_URL=https://pcdezajyayljowwgrksr.supabase.co
SUPABASE_KEY=

# Firebase Cloud Messaging (push) — opcional em dev
FCM_VAPID_KEY=
